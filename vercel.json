{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(style\\.css|app\\.js|manifest\\.json|robots\\.txt|sitemap\\.xml)",
      "dest": "frontend/$1"
    },
    {
      "src": "/(favicon\\.ico|favicon-16x16\\.png|favicon-32x32\\.png|apple-touch-icon\\.png|android-chrome-192\\.png|android-chrome-512\\.png|mask-icon\\.svg|logo\\.png)",
      "dest": "frontend/$1"
    },
    {
      "src": "/intro\\.mp4",
      "dest": "frontend/intro.mp4",
      "headers": {
        "Content-Type": "video/mp4",
        "Cache-Control": "public, max-age=86400",
        "Accept-Ranges": "bytes"
      }
    },
    {
      "src": "/(dashboard|links|qr|analytics|campaigns|domains|settings|profile|about|contact|login|register|developers|not-found)",
      "dest": "frontend/index.html"
    },
    {
      "src": "/$",
      "dest": "frontend/index.html"
    },
    {
      "src": "/([^/]+)",
      "dest": "api/index.py"
    }
  ]
}

